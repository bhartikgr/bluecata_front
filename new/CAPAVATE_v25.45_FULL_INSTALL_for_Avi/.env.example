# =============================================================================
# Capavate v23.4.2 — environment variables
# =============================================================================
# v23.4.2 changes:
#   - SMTP transporter now requires TLS on the STARTTLS path (no silent
#     cleartext fallback). The SMTP block below has explicit Gmail-tested
#     configs for both port 465 and port 587.
#   - SMTP_PASS whitespace is auto-stripped (Gmail App Passwords paste with
#     spaces; you may include or omit them — the code handles both).
#   - New admin diagnostic endpoints to validate SMTP before launch:
#       GET  /api/admin/email/config     (sanitized config; never returns pass)
#       POST /api/admin/email/test       (probes SMTP; returns actionable hint)
#       POST /api/admin/email/send-test  (sends a real test email)
#   - Boot warns if APP_URL=localhost in production (invite links would break).
# =============================================================================
# Copy this file to `.env` and fill in real values, then run:
#   bash scripts/install_avi.sh

# ============================================================================
# PRODUCTION CHECKLIST — verify these are correct before NODE_ENV=production
# ============================================================================
# - NODE_ENV=production           (required)
# - ENABLE_DEMO_SEED=0            (MUST be 0 in production)
# - DISABLE_DEV_BYPASS=1          (MUST be 1 in production)
# - ALLOW_DEV_BYPASS=0            (MUST be 0 in production)
# - ENABLE_DEV_TOOLS=false        (MUST be false in production)
# - SESSION_SECRET=<32+ random bytes>   (required; generate: openssl rand -hex 32)
# - SMTP_HOST + SMTP_USER + SMTP_PASS   (required for partner onboarding emails)
# - DATABASE_URL=                       (leave EMPTY for SQLite; Postgres not yet supported)
# - COLLECTIVE_ENABLED=1                (required for Collective + Consortium Partner surfaces)
# - CONSORTIUM_AUTO_APPROVE=1           (set to 0 for admin-approval mode)
# - APP_URL=https://your.production.domain    (used in invite email links)
# - SKIP_DB_DOCTOR=0                    (set to 1 only if you are deliberately running migrations separately)
# ============================================================================
# NEVER commit `.env` to source control.
# Full reference: DEPLOY_FOR_AVI.md section 4.
# =============================================================================

# --- Runtime ---------------------------------------------------------------
# `production` for live deploys; `development` for local work.
NODE_ENV=development
# Port the express server binds to. Default 5000.
PORT=5000

# --- Database --------------------------------------------------------------
# Leave DATABASE_URL blank to fall back to SQLite (`./data.db`) — fine for dev.
# Production should use Postgres 16+, e.g. postgres://user:pass@host:5432/db
DATABASE_URL=

# --- Auth / Sessions -------------------------------------------------------
# Signs session cookies. Must be at least 32 chars; 64 hex chars recommended.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=dev_secret_change_me_in_production_min_32_chars_xxxxxx

# v25.17 Lane E NC1 / v25.18 hard close:
# JWT_SECRET is REQUIRED in production. The server refuses to boot when
# NODE_ENV=production and JWT_SECRET is unset or < 32 chars. Generate via:
#   openssl rand -hex 32
# Every node (PM2 worker, container replica) MUST share the same value.
JWT_SECRET=dev_jwt_secret_change_me_in_production_min_32_chars_xxxxx

# Signs the v25.17 HMAC session-cookie envelope. Defaults to JWT_SECRET when
# unset. Set separately if you want to rotate cookies without invalidating
# JWTs. Same length requirements as JWT_SECRET.
SESSION_COOKIE_SECRET=

# v25.18 Lane C NC1 hard close:
# Strict-by-default in production. The legacy raw-userId cookie fallback is
# REJECTED unconditionally in production regardless of this value. In dev /
# test you can opt out (STRICT_SESSION_COOKIE=0) to keep old sessions live
# during the v25.18 cutover window. Default is strict.
STRICT_SESSION_COOKIE=1

# v25.18 Lane C NC5 hard close:
# Required if you want the legacy `/api/webhooks/payment-gateway` endpoint to
# accept events in production. Without it the endpoint returns 503. The
# per-gateway `/api/webhooks/payment-gateway/airwallex|stripe` endpoints use
# AIRWALLEX_WEBHOOK_SECRET / STRIPE_WEBHOOK_SECRET instead.
PAYMENT_WEBHOOK_SECRET=

# --- Dev-bypass safety gates (MUST be locked down in production) ----------
# In prod: DISABLE_DEV_BYPASS=1 and ALLOW_DEV_BYPASS=0. Anything else is unsafe.
DISABLE_DEV_BYPASS=0
ALLOW_DEV_BYPASS=0

# --- Feature flags ---------------------------------------------------------
# Capavate Collective subscription product (Collective sidebar, billing flows).
COLLECTIVE_ENABLED=1
# Capavate Consortium application flow (`/apply/consortium`).
CONSORTIUM_ENABLED=1
# v23.4.1: Auto-approve consortium applications on submit (1=yes, 0=manual admin review).
# Set to 0 in production if you want admin gating before credentials are issued.
CONSORTIUM_AUTO_APPROVE=1

# --- Payment gateway -------------------------------------------------------
# Ozan's directive (May 2025): AirWallex is the default gateway.
# Allowed values: `airwallex` | `stripe`
PAYMENT_GATEWAY_DEFAULT=airwallex

# --- AirWallex (required when PAYMENT_GATEWAY_DEFAULT=airwallex) ----------
# Get keys at https://www.airwallex.com/app/api
AIRWALLEX_API_KEY=
AIRWALLEX_CLIENT_ID=
# Signs incoming webhooks. Found in AirWallex dashboard → Webhooks.
AIRWALLEX_WEBHOOK_SECRET=
AIRWALLEX_API_BASE=https://api.airwallex.com

# --- Stripe (always required for Collective billing price IDs) ------------
# Get keys at https://dashboard.stripe.com/apikeys
# Live keys start with sk_live_, test keys with sk_test_.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Collective subscription tier price IDs (Stripe Dashboard → Products).
STRIPE_COLLECTIVE_BASIC_PRICE_ID=
STRIPE_COLLECTIVE_STANDARD_PRICE_ID=
STRIPE_COLLECTIVE_PREMIUM_PRICE_ID=

# --- Observability (optional but recommended in prod) ---------------------
# Sentry DSN for error reporting. Empty = disabled.
SENTRY_DSN=
# Commit SHA stamped on /api/health responses (CI builds set this).
GIT_SHA=dev
LOG_LEVEL=info

# --- Captcha (optional) ----------------------------------------------------
CAPTCHA_SECRET=

# --- Email / SMTP ----------------------------------------------------------
# Required for partner invite emails, password resets, notifications.
# Two valid TLS modes (pick ONE, do not mix):
#
#   GMAIL OPTION A — implicit TLS (port 465, recommended for Gmail)
#       SMTP_HOST=smtp.gmail.com
#       SMTP_PORT=465
#       SMTP_SECURE=true
#
#   GMAIL OPTION B — STARTTLS upgrade (port 587)
#       SMTP_HOST=smtp.gmail.com
#       SMTP_PORT=587
#       SMTP_SECURE=false
#       # v23.4.2 enforces requireTLS=true here, so the handshake refuses
#       # cleartext. If your provider does NOT support STARTTLS on 587, use
#       # Option A instead.
#
# SMTP_PASS for Gmail must be a 16-char App Password (NOT your account
# password). Generate at https://myaccount.google.com/apppasswords.
# You may paste it with or without spaces — v23.4.2 strips whitespace.
#
# To validate AFTER editing .env (and BEFORE inviting any real user):
#   curl -X POST http://localhost:5000/api/admin/email/test \
#        -H 'cookie: <your admin session cookie>'
# Should return { ok: true, mode: 'smtp', host, port, secure }.
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Capavate <no-reply@capavate.com>
# Optional. Leave empty if you want recipients to reply to SMTP_FROM directly.
SMTP_REPLY_TO=
# `smtp` | `console` | `dry_run` | `disabled`
#   smtp     — send via nodemailer (production)
#   console  — log message body to stdout (local dev)
#   dry_run  — log headers only, return delivered=true (CI/staging)
#   disabled — silent no-op, return delivered=false (feature off)
SMTP_MODE=console

# --- Storage (optional — required only for binary uploads in prod) --------
# `s3` | `local`. Leave blank for default local storage.
RESOURCES_STORAGE_PROVIDER=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Collective bridge (legacy — keep in sync with collective service) ---
BRIDGE_INBOUND_HMAC_SECRET=
# v25.18 Lane E NL2 — deprecated alias for COLLECTIVE_WEBHOOK_URL; do not set.
# BRIDGE_OUTBOUND_URL=
# v25.16 NM5 — legacy alias still accepted by bridgeStore.ts; setting either works.
BRIDGE_HMAC_SECRET=
# v25.16 cross-comp NC1 — the bridge worker only delivers events when this URL is set.
COLLECTIVE_WEBHOOK_URL=
# v25.17 Lane E NH1 — REQUIRED whenever COLLECTIVE_WEBHOOK_URL is set. The
# server refuses to boot in production if URL is set without a secret. Use the
# same secret on both the Capavate emitter and the Collective inbound verifier.
#   openssl rand -hex 32
COLLECTIVE_WEBHOOK_SECRET=

# --- App URLs --------------------------------------------------------------
# IMPORTANT: APP_URL is used to construct invite-email links (partner signup,
# password reset, etc.). In production, set this to your PUBLIC domain.
# v23.4.2 boot logs a WARNING if APP_URL contains localhost/127.0.0.1 while
# NODE_ENV=production — invite links would be unusable for external recipients.
APP_URL=http://localhost:5000
COLLECTIVE_APP_URL=http://localhost:5000
