# ============================================================
# Capavate — Environment Variables
# Sprint 28 Pass 4 — Production Readiness
# ============================================================
# Copy to .env and fill in real values before deploying.
# NEVER commit .env to source control.
# ============================================================

# --- Runtime ---
NODE_ENV=production
PORT=5000

# --- Database ---
# PostgreSQL 16+ recommended for production.
# SQLite is used in dev/test (drizzle-kit handles both via same schema).
DATABASE_URL=postgresql://capavate_app:STRONG_PASSWORD@localhost:5432/capavate_prod

# --- Auth / Sessions ---
# Must be at least 64 random hex characters.
SESSION_SECRET=change_me_to_64_random_hex_chars

# --- SMTP / Email ---
# Provider recommendations: AWS SES, SendGrid, Postmark
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=AKIAIOSFODNN7EXAMPLE
SMTP_PASS=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
SMTP_FROM=Capavate <no-reply@capavate.com>
SMTP_REPLY_TO=support@capavate.com
# Mode: smtp | console | dry_run
# console = log to stdout (safe for staging); dry_run = no-op (for tests)
SMTP_MODE=smtp

# --- Payment Gateway ---
# Set PAYMENT_GATEWAY_MODE=live for real charges; sandbox for testing.
PAYMENT_GATEWAY_MODE=sandbox
PAYMENT_GATEWAY_API_KEY=pk_live_REPLACE_ME
PAYMENT_GATEWAY_WEBHOOK_SECRET=whsec_REPLACE_ME

# --- Collective Bridge ---
# HMAC secret shared between Capavate and Collective for request signing.
BRIDGE_INBOUND_HMAC_SECRET=change_me_bridge_hmac_shared_secret
# URL where Capavate posts outbound events to Collective.
BRIDGE_OUTBOUND_URL=https://collective.capavate.com/api/bridge/inbox

# --- CDN / Storage ---
CDN_BASE_URL=https://cdn.capavate.com
STORAGE_PROVIDER=s3
S3_BUCKET=capavate-uploads-prod
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# --- App URLs ---
APP_URL=https://app.capavate.com
COLLECTIVE_APP_URL=https://collective.capavate.com

# --- Feature Flags (optional) ---
# ENABLE_3DS=true
# REQUIRE_MFA_FOR_ADMINS=true
