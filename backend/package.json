{
  "name": "rest-express",
  "version": "25.45.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "dev:windows": "set NODE_ENV=development && tsx server/index.ts",
    "dev:ps": "$env:NODE_ENV='development'; tsx server/index.ts",
    "build": "tsx script/build.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:seed:demo": "tsx scripts/seed_demo.ts",
    "db:seed:pricing": "tsx scripts/seed_pricing.ts",
    "db:purge:demo": "tsx scripts/db_purge_demo.ts",
    "db:doctor": "tsx scripts/db_doctor.ts",
    "docs:schema": "tsx scripts/generate_schema_reference.ts",
    "test": "cross-env ENABLE_DEMO_SEED=1 NODE_ENV=test vitest run",
    "test:watch": "cross-env ENABLE_DEMO_SEED=1 NODE_ENV=test vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "perf:smoke": "tsx scripts/perf_smoke.ts",
    "test:pglite": "cross-env NODE_ENV=test vitest run --reporter=verbose server/db/__tests__/portable-pglite.test.ts",
    "test:hash-replay": "cross-env NODE_ENV=test vitest run --reporter=verbose server/db/__tests__/hash-chain-replay.test.ts"
  },
